<!-- Risposte su Libri e Lettura. -->

<category>
<pattern>* LIBRI</pattern>
<think><set_topic>libri</set_topic></think>
<template>Mi piacciono molto i libri</template>
</category>

<category>
<pattern>* LIBRO</pattern>
<think><set_topic>libri</set_topic></think>
<template>Mi piace leggere. Scrivi il titolo di un libro</template>
</category>

<category>
<pattern>LEGGI</pattern>
<think><set_topic>libri</set_topic></think>
<template>Mi servirebbe uno scanner. Vuoi parlare di libri?</template>
</category>

<category>
<pattern>SAI LEGGERE</pattern>
<think><set_topic>libri</set_topic></think>
<template>Se il testo e` in forma informatica, altrimenti mi serve uno scanner</template>
</category>

<category>
<pattern>CHE LEGGI</pattern>
<think><set_topic>libri</set_topic></think>
<template>Tutto</template>
</category>

<category>
<pattern>TI PIACE LEGGERE</pattern>
<think><set_topic>libri</set_topic></think>
<template>Mi piace imparare cose nuove</template>
</category>

<!-- Vari formati della domanda -->

<category>
<pattern>PARLIAMO DI LIBRI</pattern>
<think><set_topic>libri</set_topic></think>
<template>Sono pronta. E' un argomento che mi piace</template>
</category>

<category>
<pattern>CHI E L AUTORE *</pattern>
<think><set_topic>libri</set_topic></think>
<template><srai>AUTORE <star/></srai></template>
</category>

<category>
<pattern>CHI SCRISSE *</pattern>
<think><set_topic>libri</set_topic></think>
<template><srai>AUTORE DI <star/></srai></template>
</category>

<category>
<pattern>CHI HA FATTO *</pattern>
<think><set_topic>libri</set_topic></think>
<template><srai>AUTORE DI <star/></srai></template>
</category>

<category>
<pattern>CHI HA SCRITTO *</pattern>
<think><set_topic>libri</set_topic></think>
<template><srai>AUTORE DI <star/></srai></template>
</category>

<category>
<pattern>CHE PENSI DEL LIBRO *</pattern>
<think><set_topic>libri</set_topic></think>
<template><sr/></template>
</category>


<!-- Da qui` le categorie -->
<topic name="libri">

<category>
<pattern>*</pattern>
<template><sr/></template>
</category>

<category>
<pattern>*</pattern>
<template>Ho tanti libri in memoria, ma quasto non lo trovo.<BR>
Se desideri che io sia aggiornata alla prossima versione, scrivi "Ricorda" e poi il nome l'autore e la data di pubblicazione del libro.
</template>
</category>

